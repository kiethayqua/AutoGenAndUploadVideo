# Copy this file to .env and fill in only the values you use.
# Never commit real API keys or TikTok session cookies.

# MoneyPrinterTurbo API used by auto_tiktok_orchestrator.
MONEYPRINTER_API_BASE=http://127.0.0.1:8080/api/v1
MONEYPRINTER_RUNNER=uv run python

# Agent LLM provider.
# Supported: moneyprinter, claude, anthropic, codex, openai, gemini
AUTO_TIKTOK_LLM_PROVIDER=moneyprinter
AUTO_TIKTOK_LLM_MODEL=
AUTO_TIKTOK_LLM_API_BASE=

# Optional: set this if your provider API key uses a custom env var name.
# If empty, defaults are ANTHROPIC_API_KEY, OPENAI_API_KEY, or GEMINI_API_KEY.
AUTO_TIKTOK_LLM_API_KEY_ENV=

# Provider API keys. Fill only the provider you use.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Optional examples for OpenAI-compatible gateways.
# AUTO_TIKTOK_LLM_PROVIDER=openai
# AUTO_TIKTOK_LLM_MODEL=gpt-4o-mini
# AUTO_TIKTOK_LLM_API_BASE=https://api.openai.com/v1

# Optional examples for Claude.
# AUTO_TIKTOK_LLM_PROVIDER=claude
# AUTO_TIKTOK_LLM_MODEL=claude-3-5-haiku-latest

# Optional examples for Gemini.
# AUTO_TIKTOK_LLM_PROVIDER=gemini
# AUTO_TIKTOK_LLM_MODEL=gemini-1.5-flash

# TikTokAutoUploader login URL used by its login flow.
TIKTOK_LOGIN_URL=https://www.tiktok.com/login
